# Minimal extra packages for HG680P (S905X) USB tethering only.
# ImageBuilder keeps its default OpenWrt package set; this file adds only
# USB network/tethering support requested for the custom firmware.
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y
CONFIG_PACKAGE_kmod-usb-net-rndis=y
CONFIG_PACKAGE_kmod-usb-net-ipheth=y
CONFIG_PACKAGE_usbutils=y
CONFIG_PACKAGE_usbmuxd=y
CONFIG_PACKAGE_libusbmuxd=y
CONFIG_PACKAGE_libimobiledevice=y
